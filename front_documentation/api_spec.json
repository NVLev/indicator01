                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/studies/": {
      "get": {
        "tags": [
          "Исследования"
        ],
        "summary": "Список исследований",
        "description": "Получить список исследований пользователя с пагинацией\n\n- page: Номер страницы (начинается с 1)\n- per_page: Количество исследований на странице (макс. 100)",
        "operationId": "get_user_studies_studies__get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "title": "Page"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "title": "Per Page"
            }
