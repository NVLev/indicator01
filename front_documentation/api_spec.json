    "/studies/upload": {
      "post": {
        "tags": [
          "Исследования"
        ],
        "summary": "Загрузить исследование",
        "description": "Загрузка ZIP-архива с DICOM исследованием для автоматического анализа ИИ\n\n- Максимальный размер файла: 500MB\n- Формат: ZIP архив с DICOM файлами\n- Обработка занимает до 10 минут",
        "operationId": "upload_study_studies_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_study_studies_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
